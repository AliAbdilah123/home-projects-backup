# Backend
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=file:data/app.db?_pragma=busy_timeout(5000)&_pragma=journal_mode(WAL)

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8080/api/v1

# Worker / Baileys
WORKER_LOG_LEVEL=info
# Use mock for local/test QR flow without a real WhatsApp device; use baileys for real pairing.
WORKER_MODE=mock
WORKER_SESSION_ID=local-dev
BAILEYS_AUTH_DIR=./data/baileys-auth
# Uncomment to POST worker events to the Go internal webhook.
# WORKER_API_BASE_URL=http://127.0.0.1:8080
WORKER_INTERNAL_WEBHOOK_PATH=/api/v1/webhooks/whatsapp-baileys/internal
# WORKER_INTERNAL_SECRET=change-me-in-local-env
WORKER_EXIT_AFTER_CONNECTED=true
WORKER_MOCK_DELAY_MS=750
WORKER_MOCK_QR=mock-whatsapp-qr-code
